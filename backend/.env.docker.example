# Exemple pour une copie locale. Docker Compose utilise directement le fichier
# versionné `backend/.env.docker` (voir infra/docker-compose.yml).
# Pour Python sans Docker : copie plutôt `.env.example` vers `.env`.

DJANGO_SECRET_KEY=change-me-en-production
DJANGO_DEBUG=True
# Ajoute ton IP locale si tu testes depuis un téléphone sur le Wi‑Fi
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0

DB_ENGINE=django.db.backends.postgresql
DB_NAME=cobra
DB_USER=cobra
DB_PASSWORD=cobra
# Dans le conteneur API, l’hôte Postgres est le service « db » du compose (pas localhost)
DB_HOST=db
DB_PORT=5432

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

FCM_CREDENTIALS_PATH=
FCM_PROJECT_ID=
