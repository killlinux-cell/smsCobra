DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

DB_ENGINE=django.db.backends.postgresql
DB_NAME=cobra
DB_USER=cobra
DB_PASSWORD=cobra
DB_HOST=localhost
DB_PORT=5432
# Avec Docker Compose (service api) : utiliser DB_HOST=db (voir .env.docker.example).

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Avec Docker Compose : redis://redis:6379/0
# Push Firebase : chemin absolu vers le fichier JSON du compte de service (téléchargé depuis la console Firebase)
FCM_CREDENTIALS_PATH=
# Ou variable Google standard (même fichier JSON) :
# GOOGLE_APPLICATION_CREDENTIALS=
FCM_PROJECT_ID=
