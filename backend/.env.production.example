# Exemple pour backend/.env.production sur le VPS (Docker Compose prod).
# Copier : cp backend/.env.production.example backend/.env.production puis editer les secrets.

DJANGO_SECRET_KEY=remplacer-par-une-cle-longue-et-aleatoire
DJANGO_DEBUG=False
# Domaines publics (sans https), separes par des virgules, sans espaces apres la virgule
DJANGO_ALLOWED_HOSTS=api.smsapp24.com,admin.smsapp24.com

DB_ENGINE=django.db.backends.postgresql
DB_NAME=cobra
DB_USER=cobra
DB_PASSWORD=meme-mot-de-passe-que-POSTGRES_PASSWORD-dans-infra-env-prod
DB_HOST=db
DB_PORT=5432

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

CORS_ALLOWED_ORIGINS=https://api.smsapp24.com,https://admin.smsapp24.com
CSRF_TRUSTED_ORIGINS=https://api.smsapp24.com,https://admin.smsapp24.com

BIOMETRIC_ENFORCEMENT_MODE=enforce
FACE_VERIFICATION_TOLERANCE=0.55
FACE_VERIFICATION_MODEL=hog
FACE_VERIFICATION_NUM_JITTERS=1

# Si push Firebase : placer le JSON sur le VPS dans backend/secrets/ et indiquer le chemin conteneur
FCM_CREDENTIALS_PATH=/app/secrets/firebase-service-account.json
FCM_PROJECT_ID=
